# Project configuration for agent-skills v2.2
# Copy to .claude/project.yaml in your project root
#
# If this file is absent, worker will autodetect:
#   - package.json with @angular → angular
#   - .gitlab-ci.yml → gitlab
#   - Jira URL in task → jira
#   - Figma URL in task → figma

version: "2.2"

# Adapters — which integrations to use
task-source: jira            # jira | github-issues | linear (future)
ci-cd: gitlab                # gitlab | github-actions (future)
tech-stack: angular           # angular | go | react (future)
design: figma                 # figma | none

# Project-specific settings
project:
  name: my-project
  repo: gitlab.com/team/my-project

  branches:
    main: develop
    release: "release/*"

  deploy:
    test-job: deploy-test
    prod-job: production

  # Override lint/test/build commands (otherwise adapter defaults are used)
  # commands:
  #   lint: "npx nx lint my-app"
  #   test: "npx nx test my-app"
  #   build: "npx nx build my-app"
