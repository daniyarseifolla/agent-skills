        "handoff_payload": {},
        "issues_history": []
      },
      "expected": "valid"
    }
  ],
  "invalid_examples": [
    {
      "description": "Missing required field: task_key",
      "checkpoint": {
        "completed": ["analyze"],
        "resume": "setup",
        "phase_name": "analyze",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "complexity": "S",
        "route": "MINIMAL",
        "timestamp": "2026-04-20T10:00:00Z"
      },
      "expected": "invalid",
      "reason": "missing required field: task_key"
    },
    {
      "description": "Missing required field: complexity",
      "checkpoint": {
        "task_key": "ARGO-10500",
        "completed": ["analyze"],
        "resume": "setup",
        "phase_name": "analyze",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "route": "MINIMAL",
        "timestamp": "2026-04-20T10:00:00Z"
      },
      "expected": "invalid",
      "reason": "missing required field: complexity"
    },
    {
      "description": "Missing required field: route",
      "checkpoint": {
        "task_key": "ARGO-10500",
        "completed": ["analyze"],
        "resume": "setup",
        "phase_name": "analyze",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "complexity": "S",
        "timestamp": "2026-04-20T10:00:00Z"
      },
      "expected": "invalid",
      "reason": "missing required field: route"
    },
    {
      "description": "Invalid complexity value",
      "checkpoint": {
        "task_key": "ARGO-10500",
        "completed": ["analyze"],
        "resume": "setup",
        "phase_name": "analyze",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "complexity": "XXL",
        "route": "MINIMAL",
        "timestamp": "2026-04-20T10:00:00Z"
      },
      "expected": "invalid",
      "reason": "invalid complexity value: XXL (valid: S, M, L, XL)"
    },
    {
      "description": "Invalid route value",
      "checkpoint": {
        "task_key": "ARGO-10500",
        "completed": ["analyze"],
        "resume": "setup",
        "phase_name": "analyze",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "complexity": "S",
        "route": "QUICK",
        "timestamp": "2026-04-20T10:00:00Z"
      },
