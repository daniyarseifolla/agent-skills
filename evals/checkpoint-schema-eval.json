    {
      "description": "Invalid terminal_status value",
      "checkpoint": {
        "task_key": "ARGO-10500",
        "completed": ["analyze", "setup", "impact", "plan", "implement", "review", "ship"],
        "resume": null,
        "terminal_status": "done",
        "phase_name": "ship",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
