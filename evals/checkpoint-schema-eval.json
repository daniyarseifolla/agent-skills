      "description": "resume points past invalidated phase (invariant violation)",
      "checkpoint": {
        "task_key": "ARGO-12001",
        "completed": ["analyze", "setup", "research", "impact", "plan", "plan-review", "implement", "review"],
        "resume": "ship",
        "invalidated": ["review"],
        "phase_name": "review",
        "iteration": { "plan_review": "1/3", "code_review": "1/3", "evaluate_return": "0/2" },
        "verdict": "CHANGES_REQUESTED",
        "complexity": "L",
        "route": "FULL",
        "timestamp": "2026-04-20T15:45:00Z"
      },
      "expected": "invalid",
      "reason": "resume (ship) is after earliest invalidated phase (review) — must resume at or before invalidated phase"
    }
  ],
  "complexity_route_mapping": {
    "_note": "Valid complexity-to-route pairs from complexity_matrix in core/orchestration",
    "S": "MINIMAL",
    "M": "STANDARD",
    "L": "FULL",
    "XL": "FULL"
  },
  "verdict_vocabulary": {
    "plan_review": ["APPROVED", "NEEDS_CHANGES", "REJECTED"],
    "code_review": ["APPROVED", "APPROVED_WITH_COMMENTS", "CHANGES_REQUESTED"],
    "ui_review": ["PASS", "PASS_WITH_ISSUES", "ISSUES_FOUND"],
    "evaluate_gate": ["PROCEED", "REVISE", "RETURN"]
  }
}
