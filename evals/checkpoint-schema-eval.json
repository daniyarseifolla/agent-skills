{
  "description": "Checkpoint schema validation — verifies checkpoint.yaml files conform to the canonical schema from core/orchestration/SKILL.md",
  "version": "4.0",
  "source": "core/orchestration/SKILL.md section 4 — Checkpoint Protocol",
  "location": "docs/plans/{task-key}/checkpoint.yaml",
  "required_fields": [
    "task_key",
    "completed",
    "resume",
    "phase_name",
    "iteration",
    "verdict",
    "complexity",
    "route",
    "timestamp"
  ],
  "optional_fields": [
    "invalidated",
    "terminal_status",
    "ci_disabled",
    "worktree_path",
    "app_url",
    "credentials_path",
    "last_committed_part",
    "last_commit_hash",
    "handoff_payload",
    "issues_history",
    "re_routed",
    "re_route_detail"
  ],
  "field_types": {
    "task_key": "string",
    "completed": "string[] — append-only set of phase names",
    "resume": "string|null — next phase to execute",
    "invalidated": "string[] — phases whose results are no longer valid",
    "terminal_status": "running|success|failed|stopped_by_user|loop_exceeded|null",
    "phase_name": "string — current/last completed phase name",
    "iteration": "object — { plan_review: 'N/3', code_review: 'N/3', evaluate_return: 'N/2' }",
    "verdict": "string — last verdict from current phase",
    "complexity": "S|M|L|XL",
    "route": "MINIMAL|STANDARD|FULL",
    "timestamp": "ISO-8601",
    "ci_disabled": "boolean",
    "worktree_path": "string|null",
    "app_url": "string|null",
    "credentials_path": "string|null",
    "last_committed_part": "number|null",
    "last_commit_hash": "string|null",
    "handoff_payload": "object",
    "issues_history": "object[]",
    "re_routed": "boolean",
    "re_route_detail": "string"
  },
  "enum_fields": {
    "complexity": ["S", "M", "L", "XL"],
    "route": ["MINIMAL", "STANDARD", "FULL"],
    "terminal_status": ["running", "success", "failed", "stopped_by_user", "loop_exceeded", null],
    "phase_name_values": ["analyze", "setup", "research", "impact", "plan", "plan-review", "implement", "review", "ship"],
    "completed_values": ["analyze", "setup", "research", "impact", "plan", "plan-review", "implement", "review", "ship"]
  },
  "iteration_limits": {
    "plan_review": { "max": 3, "format": "N/3" },
    "code_review": { "max": 3, "format": "N/3" },
    "evaluate_return": { "max": 2, "format": "N/2" }
  },
  "next_phase_map": {
    "analyze": "setup",
    "setup": "research (or impact if complexity == S)",
    "research": "impact",
    "impact": "plan",
    "plan": "plan-review (or implement if complexity == S)",
    "plan-review": "implement",
    "implement": "review",
    "review": "ship",
    "ship": null
  },
  "route_phase_sets": {
    "MINIMAL": [1, 2, 4, 5, 7, 8, 9],
    "STANDARD": [1, 2, 3, 4, 5, 6, 7, 8, 9],
    "FULL": [1, 2, 3, 4, 5, 6, 7, 8, 9]
  },
  "write_protocol": {
    "step_1": "Write to checkpoint.yaml.tmp",
    "step_2": "If checkpoint.yaml exists, copy to checkpoint.yaml.bak",
    "step_3": "Rename checkpoint.yaml.tmp -> checkpoint.yaml (atomic on POSIX)",
    "rule": "NEVER overwrite checkpoint.yaml directly"
  },
  "invalidation_rules": {
    "code_review_loop": {
      "trigger": "review verdict == CHANGES_REQUESTED",
      "invalidated": ["review"],
      "resume": "implement"
    },
    "plan_review_loop": {
      "trigger": "plan-review verdict == NEEDS_CHANGES",
      "invalidated": ["plan-review"],
      "resume": "plan"
    },
    "evaluate_return": {
      "trigger": "implement evaluate gate verdict == RETURN",
      "invalidated": ["implement"],
      "resume": "plan-review"
    }
  },
  "valid_examples": [
    {
      "description": "S-complexity task after analyze phase",
      "checkpoint": {
        "task_key": "ARGO-10500",
        "completed": ["analyze"],
        "resume": "setup",
        "phase_name": "analyze",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "complexity": "S",
        "route": "MINIMAL",
        "timestamp": "2026-04-20T10:00:00Z",
        "ci_disabled": false,
        "worktree_path": null,
        "app_url": null,
        "credentials_path": null,
        "last_committed_part": null,
        "last_commit_hash": null,
        "handoff_payload": {},
        "issues_history": []
      },
      "expected": "valid"
    },
    {
      "description": "M-complexity task mid-pipeline, after plan-review approved",
      "checkpoint": {
        "task_key": "ARGO-11234",
        "completed": ["analyze", "setup", "research", "impact", "plan", "plan-review"],
        "resume": "implement",
        "phase_name": "plan-review",
        "iteration": { "plan_review": "1/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "APPROVED",
        "complexity": "M",
        "route": "STANDARD",
        "timestamp": "2026-04-20T12:30:00Z",
        "ci_disabled": true,
        "worktree_path": "/tmp/worktree-ARGO-11234",
        "app_url": "http://localhost:4200",
        "credentials_path": null,
        "last_committed_part": null,
        "last_commit_hash": "abc1234",
        "handoff_payload": {
          "artifact_path": "docs/plans/ARGO-11234/plan.md",
          "key_decisions": ["Use signals over BehaviorSubject"],
          "complexity": "M"
        },
        "issues_history": []
