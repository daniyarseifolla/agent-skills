        "iteration": { "plan_review": "0/3", "code_review": "1/3", "evaluate_return": "0/2" },
        "verdict": "APPROVED",
        "complexity": "S",
        "route": "MINIMAL",
        "timestamp": "2026-04-20T16:00:00Z",
        "ci_disabled": false,
        "worktree_path": null,
        "app_url": null,
        "credentials_path": null,
        "last_committed_part": 1,
        "last_commit_hash": "ghi9012",
        "handoff_payload": {},
        "issues_history": []
      },
      "expected": "valid"
    },
    {
      "description": "XL task with re-routing from M to XL",
      "checkpoint": {
        "task_key": "ARGO-13000",
        "completed": ["analyze", "setup", "research", "impact", "plan"],
        "resume": "plan-review",
        "phase_name": "plan",
        "iteration": { "plan_review": "0/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "PROCEED",
        "complexity": "XL",
        "route": "FULL",
        "timestamp": "2026-04-20T09:15:00Z",
        "re_routed": true,
        "re_route_detail": "M->XL after planning discovered 8 AC and 5 modules",
        "ci_disabled": true,
        "worktree_path": "/tmp/worktree-ARGO-13000",
        "app_url": "http://localhost:4200",
        "credentials_path": ".credentials",
        "last_committed_part": null,
        "last_commit_hash": null,
        "handoff_payload": {},
        "issues_history": []
      },
      "expected": "valid"
    },
    {
      "description": "Pipeline stopped by user",
      "checkpoint": {
        "task_key": "ARGO-10999",
        "completed": ["analyze", "setup", "impact", "plan"],
        "resume": "implement",
        "terminal_status": "stopped_by_user",
        "phase_name": "plan-review",
        "iteration": { "plan_review": "1/3", "code_review": "0/3", "evaluate_return": "0/2" },
        "verdict": "APPROVED",
