    {
      "description": "L-complexity task with code review loop-back",
      "checkpoint": {
        "task_key": "ARGO-12001",
        "completed": ["analyze", "setup", "research", "impact", "plan", "plan-review", "implement", "review"],
        "resume": "implement",
        "invalidated": ["review"],
        "phase_name": "review",
        "iteration": { "plan_review": "1/3", "code_review": "1/3", "evaluate_return": "0/2" },
        "verdict": "CHANGES_REQUESTED",
        "complexity": "L",
        "route": "FULL",
